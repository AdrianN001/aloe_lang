import {tcp} from "@std::net/socket/tcp.aloe"; 

async fun main(){
    let addr = "127.0.0.1";
    let port = 4565;

    let server_stream = await tcp::connect_async(addr, port);
    println("Connected to the server on[", addr, ":", port,"]");

    print("Write something:>>","");
    let inpt = "";

    while inpt = __input() {
        await server_stream.write(inpt.as_buffer())!;
        print("Write something:>>","");
    }

}

launch main()
import {json} from "@std::parser/json.aloe";

let test = {
    "hello": "world",
    "users": [
        {
            "name": "Max Musterman",
            "age": 30,
            "has_job": true,
        },
        {
            "name": "Sample",
            "age": 99,
            "has_job": null
        }
    ]
}

let json_str = json::to_str(test);
println(json_str)

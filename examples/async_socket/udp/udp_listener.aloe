import {udp} from "@std::net/socket/udp.aloe";

async fun main(){

    let addr = "127.0.0.1";
    let port = 4566;

    let socket = await udp::bind_async(addr, port)?;

    for {
        let _ = await socket.recv_from_async();
        let buffer = _[0];
        let addr = _[1];

        println("got: ${buffer.as_str}, from: ${addr}");
    }
}

__spawn(main())